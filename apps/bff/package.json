{
  "name": "bff",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "lint": "eslint .",
    "build": "wrangler build",
    "deploy": "wrangler deploy --minify",
    "generate-types": "wrangler types",
    "type-check": "pnpm generate-types && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio",
    "d1:migrate:local": "wrangler d1 migrations apply cola-finance-db --local",
    "d1:migrate:prod": "wrangler d1 migrations apply cola-finance-db --remote",
    "d1:seed:user-from-template": "pnpx tsx scripts/seed-user-from-template.ts demo@demo.com demo@demo.com",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.3",
    "@libsql/client": "^0.17.0",
    "@repo/shared-types": "workspace:*",
    "better-auth": "^1.4.14",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.4",
    "mysql2": "^3.16.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "@vitest/ui": "^1.0.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.53.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.59.2"
  }
}
