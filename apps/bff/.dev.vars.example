# BFF Environment Variables (Cloudflare Workers)
# Note: Rename to .dev.vars for local development

# JWT Secret for token generation
JWT_SECRET=your-secret-key-here-change-in-production

# Engine API URL (internal)
ENGINE_API_URL=http://localhost:3001

# Exchange Rate API Key (ExchangeRate-API.com)
EXCHANGE_API_KEY=your-api-key-here

# Environment
ENVIRONMENT=development
